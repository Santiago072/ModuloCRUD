# ============================================================
# Variables de Entorno — Módulo CRUD
# Copia este archivo como .env y completa con tus valores reales.
# NUNCA subas el archivo .env a GitHub.
# ============================================================

# -- Base de Datos --
DB_HOST=db
DB_NAME=modulocrud
DB_USER=crud_user
DB_PASSWORD=CAMBIA_ESTA_CLAVE_SEGURA

# -- Backend Node.js --
PORT=3000

# -- URL de la API (usada por el Frontend en build) --
# En producción (VPS): https://modulocrud.slscode.online/api
# En desarrollo local: http://localhost:3000/api
VITE_API_URL=https://modulocrud.slscode.online/api
